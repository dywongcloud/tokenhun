TOKENHUB_API_KEY=sk-your-tokenhub-api-key
# Singapore: https://tokenhub-intl.tencentcloudmaas.com (backup: https://tokenhub-intl.tencentcloudmaas.tech)
# Guangzhou: https://tokenhub.tencentcloudmaas.com (backup: https://tokenhub.tencentcloudmaas.tech)
TOKENHUB_BASE_URL=https://tokenhub-intl.tencentcloudmaas.com
# Optional: TokenPlan subscription key for /plan/anthropic/v1/messages (falls back to TOKENHUB_API_KEY).
# TOKENHUB_PLAN_API_KEY=sk-your-tokenplan-api-key

# Required: shared secret clients must present to call THIS proxy (not the TokenHub key).
# Send as 'Authorization: Bearer <key>' or 'x-api-key: <key>'.
PROXY_API_KEY=change-me
